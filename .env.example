# Hakili Lab — Configuration environnement
# Copiez ce fichier en .env et renseignez vos valeurs
# Ne commitez JAMAIS le fichier .env

# --- Environnement ---
APP_ENV=development

# --- Stockage ---
DATA_DIR=./runs

# --- Fournisseur IA (anthropic | openai | google) ---
AI_PROVIDER=anthropic

# --- Clés API (une seule requise selon AI_PROVIDER) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# --- Modèles (optionnel, valeurs par défaut ci-dessous) ---
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
GOOGLE_MODEL=gemini-2.0-flash

# --- Seuils qualité image ---
MIN_IMAGE_WIDTH=1000
MIN_IMAGE_HEIGHT=1000
MIN_BRIGHTNESS=60
MAX_BRIGHTNESS=235
BLUR_THRESHOLD=100.0

# --- Seuils de confiance IA ---
CONFIDENCE_REVIEW_THRESHOLD=0.75
