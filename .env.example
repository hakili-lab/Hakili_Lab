# Hakili Lab — Configuration environnement
# Copiez ce fichier en .env et renseignez vos valeurs
# Ne commitez JAMAIS le fichier .env

# ── Anthropic Claude ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Modèles Claude ─────────────────────────────────────────────────────────────
# Sonnet 4.6 = meilleur rapport qualité/prix (1.7× moins cher qu'Opus 4.7)
# Pour revenir à Opus (qualité max) : claude-opus-4-8
CLAUDE_MODEL_HEAVY=claude-sonnet-4-6
CLAUDE_MODEL_LIGHT=claude-haiku-4-5-20251001

# ── Google Gemini — transcription vision ($0 jusqu'à 1M tokens/jour) ──────────
# Clé gratuite : https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
VISION_PROVIDER=gemini        # "gemini" | "claude"

# ── DeepSeek — correction (V3) + diagnostic (R1) + remédiation ───────────────
# Clé : https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── Mistral — diagnostic + remédiation en français académique ────────────────
# Clé : https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── Choix des providers par étape ────────────────────────────────────────────
GRADING_PROVIDER=deepseek      # "deepseek" | "claude"
DIAGNOSTIC_PROVIDER=deepseek   # "deepseek" | "mistral" | "claude"
REMEDIATION_PROVIDER=mistral   # "mistral"  | "deepseek" | "claude"

# ── Seuils pipeline ────────────────────────────────────────────────────────────
CONFIDENCE_REVIEW_THRESHOLD=0.75
IMAGE_MIN_RESOLUTION=1000
IMAGE_BLUR_THRESHOLD=100.0

# ── Stockage local ─────────────────────────────────────────────────────────────
RUNS_DIR=./runs
SUBJECT=mathematics
