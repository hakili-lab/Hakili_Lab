{% raw %}
\newcommand{\HakiliSection}[1]{%
  \vspace{14pt}%
  \noindent
  \colorbox{HakiliBlue}{%
    \parbox{\dimexpr\linewidth-2\fboxsep\relax}{%
      \vspace{2pt}%
      \sffamily\bfseries\normalsize\textcolor{white}{\MakeUppercase{#1}}%
      \vspace{2pt}%
    }%
  }%
  \par\nointerlineskip\vspace{1pt}%
  \HakiliRule
  \vspace{8pt}%
}
{% endraw %}

%% ── Badge de compétence ──────────────────────────────────
{% raw %}
\newcommand{\skillbadge}[1]{%
  \ifthenelse{\equal{#1}{acquis}}{%
    \colorbox{HakiliGreenLight}{%
      \textcolor{HakiliGreen}{\sffamily\bfseries\small Acquis}}%
  }{\ifthenelse{\equal{#1}{partial}}{%
    \colorbox{HakiliAccent!25}{%
      \textcolor{HakiliAccent!80!black}{\sffamily\bfseries\small Part.~acquis}}%
  }{\ifthenelse{\equal{#1}{weak}}{%
    \colorbox{HakiliRedLight}{%
      \textcolor{HakiliRed}{\sffamily\bfseries\small Non~acquis}}%
  }{%
    \colorbox{HakiliLightGray}{%
      \textcolor{HakiliGray}{\sffamily\bfseries\small ---}}%
  }}}%
}
{% endraw %}

