<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <title>{{ DOC_TITLE }} — {{ STUDENT_NAME }}</title>
  <style>
    /* ===== PAGE ===== */
    @page {
      size: A4;
      margin-top: 28mm;
      margin-left: 20mm;
      margin-right: 18mm;
      margin-bottom: 22mm;

      @frame header_frame {
        -pdf-frame-content: page_header;
        left: 20mm; width: 172mm; top: 7mm; height: 16mm;
      }
      @frame footer_frame {
        -pdf-frame-content: page_footer;
        left: 20mm; width: 172mm; bottom: 5mm; height: 14mm;
      }
    }

    /* ===== BASE ===== */
    * { box-sizing: border-box; }
    body {
      font-family: {{ FONT_NAME }}, Helvetica, sans-serif;
      font-size: 10.5pt;
      color: #1a1a1a;
      line-height: 1.55;
    }
    p { margin: 0 0 4pt 0; }

    /* ===== EN-TÊTE / PIED DE PAGE ===== */
    .hdr-left   { font-size: 9pt; font-weight: bold; color: #1A5276; padding: 0; }
    .hdr-center { font-size: 8pt; color: #5D6D7E; text-align: center; padding: 0; }
    .hdr-right  { font-size: 8pt; color: #5D6D7E; text-align: right; padding: 0; }

    /* ===== EN-TÊTE INFO (encadré, sobre) ===== */
    .info-box-bordered {
      width: 100%;
      border: 1pt solid #1A5276;
      border-collapse: collapse;
      margin-bottom: 12pt;
    }
    .info-box-bordered td { padding: 7pt 12pt; vertical-align: middle; }
    .info-name { font-size: 12.5pt; font-weight: bold; color: #1A5276; }
    .info-meta {
      font-size: 8.5pt; color: #333; text-align: right; line-height: 1.5;
      border-left: 1pt solid #1A5276;
    }

    /* ===== INFO BOX ===== */
    .info-box {
      background: #EAF2FF;
      border-left: 3pt solid #2E86C1;
      padding: 6pt 10pt;
      margin-bottom: 18pt;
      font-size: 9pt;
    }

    /* ===== SÉRIE (titre encadré, sobre) ===== */
    .title-box {
      border: 1pt solid #1A5276;
      color: #1A5276;
      font-weight: bold;
      font-size: 10.5pt;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.3pt;
      padding: 6pt 10pt;
      margin-top: 18pt;
      margin-bottom: 10pt;
    }

    /* ===== EXERCICE ===== */
    .exo-block {
      margin-bottom: 12pt;
      page-break-inside: avoid;
    }
    .exo-title {
      display: inline-block;
      background-color: #D6EAF8;
      color: #1A5276;
      font-weight: bold;
      font-size: 10.5pt;
      text-decoration: underline;
      padding: 2pt 8pt;
      margin-bottom: 6pt;
    }

    /* ===== ÉNONCÉ (contexte du problème) ===== */
    .enonce-block {
      background: #F4F6F7;
      border-left: 3pt solid #808B96;
      padding: 5pt 10pt;
      margin-bottom: 5pt;
      font-size: 10.5pt;
      line-height: 1.4;
    }

    /* ===== TÂCHES NUMÉROTÉES ===== */
    .tasks-wrap { width: 100%; border-collapse: collapse; margin-bottom: 5pt; }
    .task-num  {
      width: 20pt;
      vertical-align: top;
      font-weight: bold;
      color: #1A5276;
      font-size: 10.5pt;
      padding: 1.5pt 5pt 1.5pt 0;
    }
    .task-text {
      vertical-align: top;
      font-size: 10.5pt;
      line-height: 1.4;
      padding: 1.5pt 0;
    }

    /* ===== INDICE ===== */
    .hint-box {
      border: 0.5pt dashed #D4AC0D;
      background: #FEFAF2;
      padding: 5pt 9pt;
      margin-top: 4pt;
      font-size: 8.5pt;
      font-style: italic;
      color: #7D6608;
    }

    /* ===== ESPACE RÉPONSE ===== */
    .answer-space {
      border: 0.5pt solid #C8CBD0;
      background: #FAFAFA;
      height: 22mm;
      margin-top: 6pt;
    }

    /* ===== PIED DE DOCUMENT ===== */
    .doc-footer {
      margin-top: 22pt;
      border-top: 0.5pt solid #ddd;
      padding-top: 5pt;
      text-align: center;
      font-size: 8pt;
      color: #7f8c8d;
      font-style: italic;
    }
  </style>
</head>
<body>

<!-- ── EN-TÊTE DE PAGE ──────────────────────────────────────────── -->
<div id="page_header">
  <table style="width:100%; border-collapse:collapse;">
    <tr>
      <td class="hdr-left">HAKILI LAB</td>
      <td class="hdr-right">{{ DOC_TITLE }}</td>
    </tr>
  </table>
  <hr style="border:0; border-top:1.4pt solid #C0392B; margin-top:3pt;"/>
</div>

<!-- ── PIED DE PAGE ─────────────────────────────────────────────── -->
<div id="page_footer">
  <hr style="border:0; border-top:0.8pt solid #1A5276; margin-bottom:3pt;"/>
  <p style="text-align:center; font-size:8pt; font-weight:bold; color:#1A5276; margin:0; letter-spacing:0.2pt;">
    HAKILI LAB &nbsp;&#8226;&nbsp; L'EXIGENCE AU SERVICE DE L'EXCELLENCE
  </p>
  <p style="text-align:center; font-size:7.5pt; color:#5D6D7E; margin:2pt 0 0 0;">
    Page <pdf:pagenumber/> / <pdf:pagecount/>
  </p>
</div>

<!-- ── EN-TÊTE INFO (encadré) ───────────────────────────────────── -->
<table class="info-box-bordered">
  <tr>
    <td class="info-name">{{ STUDENT_NAME }}</td>
    <td class="info-meta">{{ DOC_TITLE }}<br/>{{ DATE }}</td>
  </tr>
</table>

<!-- ── INFO ─────────────────────────────────────────────────────── -->
<div class="info-box">
{% if is_enrichment %}
  <strong>{{ total }} exercice{% if total > 1 %}s{% endif %} d'approfondissement</strong>
  — niveau 2nde / 1ère scientifique. {{ DOC_SUBTITLE }}
  Résous chaque exercice sans aide extérieure.
{% else %}
  <strong>{{ total }} exercice{% if total > 1 %}s{% endif %} de remédiation</strong>
  répartis en {{ series|length }} série{% if series|length > 1 %}s{% endif %}.
  Ces exercices ciblent les lacunes identifiées lors de la correction.
  Travaille chaque série dans l'ordre indiqué.
{% endif %}
</div>

<!-- ── SÉRIES D'EXERCICES ────────────────────────────────────────── -->
{% for serie in series %}

<div class="title-box">Série {{ serie.idx }} — {{ serie.topic }}</div>

{% for ex in serie.exercises %}
<div class="exo-block">

  <!-- Titre de l'exercice -->
  <div class="exo-title">Exercice N°{{ ex.number }} :</div>

  <!-- Énoncé (contexte du problème) — affiché si non vide -->
  {% if ex.enonce %}
  <div class="enonce-block">{{ ex.enonce }}</div>
  {% endif %}

  <!-- Questions numérotées -->
  {% if ex.has_tasks %}
  <table class="tasks-wrap">
    {% for task in ex.tasks %}
    <tr>
      <td class="task-num">{{ loop.index }}.</td>
      <td class="task-text">{{ task }}</td>
    </tr>
    {% endfor %}
  </table>
  {% endif %}

  <!-- Indice -->
  {% if ex.has_hint %}
  <div class="hint-box"><strong>Indice</strong> — <em>{{ ex.hint }}</em></div>
  {% endif %}

  <!-- Espace réponse -->
  <div class="answer-space"></div>

</div>
{% endfor %}

{% endfor %}

<!-- ── PIED DE DOCUMENT ──────────────────────────────────────────── -->
<div class="doc-footer">
  Feuille générée par Hakili Lab IA — Utilisée dans le cadre d'un suivi pédagogique personnalisé.
</div>

</body>
</html>
