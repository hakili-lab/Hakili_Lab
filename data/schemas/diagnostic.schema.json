{
  "type": "object",
  "required": ["copy_id", "strengths", "weaknesses", "skills", "remediation_plan"],
  "properties": {
    "copy_id": {"type": "string"},
    "strengths": {"type": "array", "items": {"type": "string"}},
    "weaknesses": {"type": "array", "items": {"type": "string"}},
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "level", "evidence"],
        "properties": {
          "name": {"type": "string"},
          "level": {"type": "string", "enum": ["mastered", "partial", "weak", "unknown"]},
          "evidence": {"type": "string"}
        }
      }
    },
    "remediation_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "topic", "action"],
        "properties": {
          "priority": {"type": "integer", "minimum": 1},
          "topic": {"type": "string"},
          "action": {"type": "string"}
        }
      }
    }
  }
}
