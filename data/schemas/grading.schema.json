        "properties": {
          "question_id": {"type": "string"},
          "score": {"type": "number"},
          "max_score": {"type": "number"},
          "observed_answer": {"type": "string"},
          "expected_answer": {"type": "string"},
          "comment": {"type": "string"},
          "confidence": {"type": "number"},
          "requires_teacher_review": {"type": "boolean"}
        }
      }
    }
  }
}
