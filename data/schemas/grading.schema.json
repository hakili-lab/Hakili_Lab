  "required": ["student_copy_id", "total_score", "max_score", "questions"],
  "properties": {
    "student_copy_id": {"type": "string"},
    "total_score": {"type": "number"},
    "max_score": {"type": "number"},
    "questions": {
      "type": "array",
      "items": {
